{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with personal and loyalty information",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Firebase Auth unique User ID"
        },
        "name": {
          "type": "string",
          "description": "Personal name of the customer or staff"
        },
        "email": {
          "type": "string",
          "description": "Email address"
        },
        "phone": {
          "type": "string",
          "description": "South African contact phone number"
        },
        "address": {
          "type": "string",
          "description": "Gauteng delivery street address"
        },
        "role": {
          "type": "string",
          "enum": ["customer", "admin"],
          "description": "RBAC role of the authenticated profile"
        },
        "pointsBalance": {
          "type": "integer",
          "description": "Lekker Coins loyalty credit balance"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Database insertion timestamp"
        }
      },
      "required": ["userId", "name", "email", "createdAt"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "Inventory stock counts for registered menu dishes",
      "type": "object",
      "properties": {
        "itemId": {
          "type": "string",
          "description": "Dish unique registration id reference"
        },
        "itemName": {
          "type": "string",
          "description": "Human-readable item descriptor"
        },
        "stock": {
          "type": "integer",
          "description": "Current kitchen raw stock unit count"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last top-up or decrement log timestamp"
        }
      },
      "required": ["itemId", "stock"]
    },
    "ServiceFeedback": {
      "title": "ServiceFeedback",
      "description": "User service rating and feedback",
      "type": "object",
      "properties": {
        "feedbackId": {
          "type": "string",
          "description": "Unique feedback submission id"
        },
        "userId": {
          "type": "string",
          "description": "The customer reviewer auth uid"
        },
        "userName": {
          "type": "string",
          "description": "Optional custom display name"
        },
        "rating": {
          "type": "integer",
          "description": "Overall service score from 1 up to 5 stars"
        },
        "comment": {
          "type": "string",
          "description": "Written feedback review comment"
        },
        "transactionId": {
          "type": "string",
          "description": "Associated unique transaction or order ID references"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Submission timestamp"
        }
      },
      "required": ["rating", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document catalog with isolation rules mapping to auth.uid"
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Real-time menu item inventory stock list monitored by staff and clients"
    },
    "/feedback/{feedbackId}": {
      "schema": "ServiceFeedback",
      "description": "Review evaluations and typed ratings written by clients upon completing transactions"
    }
  }
}
