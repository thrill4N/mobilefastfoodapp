rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Global Reusable Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based helper querying user's document
    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isAdminUser() {
      return isSignedIn() && (
        getUserRole(request.auth.uid) == 'admin' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // User Profile Rules Match Block
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdminUser());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminUser());
      
      allow create: if isSignedIn() && 
        request.auth.uid == userId &&
        isValidUserProfile(incoming()) &&
        // Prevent users from starting as 'admin' in user creation bypasses
        incoming().role == 'customer';

      allow update: if isSignedIn() && (
        // Owner Update: limited updates, cannot change role to admin
        (request.auth.uid == userId && 
         isValidUserProfile(incoming()) && 
         incoming().role == existing().role && 
         incoming().userId == existing().userId &&
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'address', 'pointsBalance', 'createdAt'])) ||
        // Admin Update: full edit
        (isAdminUser() && isValidUserProfile(incoming()))
      );

      allow delete: if isAdminUser();
    }

    // Validation Blueprint for User Profiles
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'name', 'email', 'createdAt']) &&
        data.keys().size() <= 8 &&
        data.userId is string &&
        data.userId.size() <= 128 &&
        data.name is string &&
        data.name.size() > 0 &&
        data.name.size() <= 200 &&
        data.email is string &&
        data.email.size() <= 256 &&
        (!('phone' in data) || data.phone is string && data.phone.size() <= 50) &&
        (!('address' in data) || data.address is string && data.address.size() <= 500) &&
        (!('role' in data) || data.role in ['customer', 'admin']) &&
        (!('pointsBalance' in data) || data.pointsBalance is int);
    }

    // Inventory Rules Match Block
    match /inventory/{itemId} {
      // Any authenticated user can read current stocks
      allow get, list: if isSignedIn();

      // Only Admin or Staff is authorized to update/create stock records
      allow create: if isAdminUser() && 
        isValidInventoryItem(incoming());

      allow update: if isAdminUser() &&
        isValidInventoryItem(incoming()) &&
        incoming().itemId == existing().itemId;

      allow delete: if isAdminUser();
    }

    // Validation Blueprint for Inventory Items
    function isValidInventoryItem(data) {
      return data.keys().hasAll(['itemId', 'stock']) &&
        data.keys().size() <= 5 &&
        data.itemId is string &&
        data.itemId.size() <= 128 &&
        data.stock is int &&
        data.stock >= 0 &&
        data.stock <= 99999 &&
        (!('itemName' in data) || data.itemName is string && data.itemName.size() <= 300);
    }

    // Feedback Rules Match Block
    match /feedback/{feedbackId} {
      // Admins can read all feedbacks, and owners of feedback can retrieve theirs
      allow get: if isAdminUser() || (isSignedIn() && existing().userId == request.auth.uid);
      allow list: if isAdminUser() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // Authenticated users can create feedback
      allow create: if isSignedIn() &&
        isValidId(feedbackId) &&
        isValidServiceFeedback(incoming()) &&
        // Secure identity mapping: prevent users from spoofing another's uid
        (!('userId' in incoming()) || incoming().userId == request.auth.uid);

      // No client updates or deletions allowed; feedback is immutable
      allow update, delete: if isAdminUser();
    }

    // Validation Blueprint for Service Feedbacks
    function isValidServiceFeedback(data) {
      return data.keys().hasAll(['rating', 'createdAt']) &&
        data.keys().size() <= 7 &&
        data.rating is int &&
        data.rating >= 1 &&
        data.rating <= 5 &&
        data.createdAt is string &&
        (!('feedbackId' in data) || data.feedbackId is string && data.feedbackId.size() <= 128) &&
        (!('userId' in data) || data.userId is string && data.userId.size() <= 128) &&
        (!('userName' in data) || data.userName is string && data.userName.size() <= 250) &&
        (!('comment' in data) || data.comment is string && data.comment.size() <= 1200) &&
        (!('transactionId' in data) || data.transactionId is string && data.transactionId.size() <= 128);
    }
  }
}
